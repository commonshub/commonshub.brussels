services:
  web:
    build:
      context: .
      dockerfile: Dockerfile
    image: commonshub-brussels:latest
    container_name: commonshub-web
    restart: unless-stopped
    ports:
      - "3000:3000"
    volumes:
      # Shared read/write data directory populated by the separate CHB service.
      - ./data:/data
    environment:
      - NODE_ENV=production
      - DATA_DIR=/data

      # Website runtime secrets only. Keep fetcher secrets in docker-compose.chb.yml.example.
      - AUTH_DISCORD_ID=${AUTH_DISCORD_ID}
      - AUTH_DISCORD_SECRET=${AUTH_DISCORD_SECRET}
      - RESEND_API_KEY=${RESEND_API_KEY}
      - NEXTAUTH_URL=${NEXTAUTH_URL:-http://localhost:3000}
      - NEXTAUTH_SECRET=${NEXTAUTH_SECRET}
      - WEBHOOK_SECRET=${WEBHOOK_SECRET}

    # Read-only root filesystem (supply-chain attack mitigation)
    # Only /data, /tmp, and /run are writable
    read_only: true
    tmpfs:
      - /tmp
      - /run
    security_opt:
      - no-new-privileges:true

    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:3000"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

    deploy:
      resources:
        limits:
          cpus: '2'
          memory: 2G
